---
interface Props {
  title: string;
  body: string;
  category: string;
  date: string;
  readTime: string;
  author: string;
  initials: string;
  url: string;
}

const { title, body, category, date, readTime, author, initials, url } = Astro.props;
---
<article class="tech-card p-8 md:p-10 space-y-4 hover:border-electric transition-all relative">
    <div class="flex flex-wrap items-center gap-3 font-mono">
        <span class="text-[10px] bg-primary text-white px-2.5 py-1 font-bold tracking-widest uppercase">> {category}</span>
        <span class="text-[10px] text-black/60 font-semibold uppercase">> PUBLISHED: {date}</span>
        <span class="text-[10px] text-primary font-semibold uppercase">> {readTime}</span>
    </div>
    <h2 class="text-2xl md:text-3xl uppercase text-black hover:text-primary transition-colors cursor-pointer brand-font mt-2">
        <a href={url}>{title}</a>
    </h2>
    <p class="text-black text-sm md:text-base leading-relaxed line-clamp-3">{body}</p>
    
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between border-t-2 border-primary pt-4 mt-6 gap-4 font-mono">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-black flex items-center justify-center text-white text-xs font-bold">
                {initials}
            </div>
            <span class="text-[10px] font-bold uppercase tracking-wider text-black">> BY: {author.toUpperCase()}</span>
        </div>
        <a href={url} class="btn-sharp px-4 py-2 text-[10px]">> READ LOG</a>
    </div>
</article>
