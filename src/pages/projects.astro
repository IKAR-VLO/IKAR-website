---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Layout title="IKAR Projects">
    <Header />
    <main class="flex-grow max-w-7xl w-full mx-auto px-6 py-12 md:px-12">
        <div class="space-y-4 mb-12 border-b-2 border-primary/20 pb-8">
            <h1 class="text-3xl md:text-5xl uppercase tracking-tight text-primary brand-font">Active Projects</h1>
            <p class="text-sm text-black/70 max-w-2xl font-mono">
                > Physical engineering models, launches, and hardware tests run by our high school members.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {projects.map(p => (
                <ProjectCard 
                    title={p.data.title}
                    description={p.data.description}
                    category={p.data.category}
                    badge={p.data.badge}
                    duration={p.data.duration}
                    status={p.data.status}
                    lead={p.data.lead}
                    url={`/projects/${p.slug}`}
                />
            ))}
        </div>
    </main>
    <Footer />
</Layout>
