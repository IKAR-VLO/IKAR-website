---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Join IKAR">
    <main class="flex-grow max-w-7xl w-full mx-auto px-6 py-12 md:px-12">
        <section class="space-y-12 mt-8">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center pt-4">
                <div class="lg:col-span-7 space-y-6">
                    <span class="inline-block text-[10px] bg-black text-electric px-3 py-1 font-bold tracking-widest uppercase font-mono">
                        > JOIN IKAR
                    </span>
                    <h1 class="text-4xl md:text-5xl lg:text-6xl tracking-tight text-black leading-[1.1] brand-font">
                        Get Involved
                    </h1>
                    <p class="text-black/80 text-sm md:text-base leading-relaxed max-w-2xl">
                        Are you a high school student interested in space science, amateur rocketry, electronics, or physics? IKAR is a great space to build real models, run hardware, write code, and learn with active teammates.
                    </p>
                    
                    <!-- Easy Contact Call-To-Action Box -->
                    <div class="border-l-2 border-black pl-4 py-4 space-y-3 mt-8 max-w-2xl">
                        <p class="text-[10px] uppercase text-gray-500 font-bold font-mono">> HOW TO APPLY</p>
                        <p class="text-sm text-black leading-relaxed">
                            We don't have boring entry tests. Just write us a friendly email with your name, school, class grade, and what you would like to work on!
                        </p>
                        <div class="pt-2">
                            <a href="mailto:ikar.kolo@gmail.com" class="btn-sharp inline-block px-6 py-3 text-xs tracking-wider">
                                <i class="fa-solid fa-paper-plane mr-2"></i> Send Us an Email
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Membership requirements -->
                <div class="lg:col-span-5 bg-white border-2 border-primary p-8 space-y-6 relative overflow-hidden flex flex-col justify-between min-h-[300px]">
                    <div class="space-y-4 font-mono">
                        <h2 class="text-2xl uppercase text-primary brand-font">Criteria</h2>
                        <div class="border-l-2 border-black pl-4 py-2">
                            <p class="text-[10px] uppercase text-gray-500 font-bold">> REQUIREMENT 1</p>
                            <p class="text-sm font-bold text-black uppercase">Must be an active HS student</p>
                        </div>
                        <div class="border-l-2 border-black pl-4 py-2">
                            <p class="text-[10px] uppercase text-gray-500 font-bold">> REQUIREMENT 2</p>
                            <p class="text-sm font-bold text-black uppercase">Willing to learn & collaborate</p>
                        </div>
                        <div class="border-l-2 border-primary pl-4 py-2">
                            <p class="text-[10px] uppercase text-gray-500 font-bold">> REQUIREMENT 3</p>
                            <p class="text-sm font-bold text-black uppercase">Interest in STEAM fields</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
