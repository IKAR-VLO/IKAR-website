---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<Layout title="IKAR Journal - Logs">
    <Header />
    <main class="flex-grow max-w-7xl w-full mx-auto px-6 py-12 md:px-12">
        <div class="space-y-4 mb-12 border-b-2 border-primary/20 pb-8">
            <h1 class="text-3xl md:text-5xl uppercase tracking-tight text-primary brand-font">Mission Logs</h1>
            <p class="text-sm text-black/70 max-w-2xl font-mono">
                > Follow our progress. Safety first! We conduct every test with the highest possible safety standard. Do not copy what we do without proper safety procedures.
            </p>
        </div>

        <div class="grid grid-cols-1 gap-8">
            {posts.map(p => (
                <PostCard 
                    title={p.data.title}
                    body={p.body.slice(0, 150) + "..."}
                    category={p.data.category}
                    date={p.data.date}
                    readTime={p.data.readTime}
                    author={p.data.author}
                    initials={p.data.initials}
                    url={`/journal/${p.slug}`}
                />
            ))}
        </div>
    </main>
    <Footer />
</Layout>
